    "js-yaml": "4.2.0",
    "remeda": "^2.33.6",
    "string-argv": "^0.3.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-coverage": "^4.0.2",
    "typedoc-plugin-markdown": "^4.10.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "rimraf": "6.1.2",
    "typescript": "6.0.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "prettier": ">=3.0.0"
