{
  "name": "orval",
  "version": "8.21.0",
  "description": "A swagger client generator for typescript",
  "keywords": [
    "angular",
    "axios",
    "client",
    "code-generation",
    "data fetching",
    "effect",
    "fetch",
    "hono",
    "mock",
    "msw",
    "open-api",
    "react",
    "react-query",
    "rest",
    "svelte",
    "svelte-query",
    "swagger",
    "swr",
    "vue",
    "vue-query",
    "zod"
  ],
  "homepage": "https://orval.dev",
  "bugs": {
    "url": "https://github.com/orval-labs/orval/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Victor Bury",
    "email": "victor@anymaniax.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orval-labs/orval.git"
  },
  "bin": {
    "orval": "./dist/bin/orval.mjs"
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map",
    "!dist/**/*.d.mts.map"
