    "./package.json": "./package.json"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "@orval/angular": "8.21.0",
    "@orval/axios": "8.21.0",
    "@orval/core": "8.21.0",
    "@orval/effect": "8.21.0",
    "@orval/fetch": "8.21.0",
    "@orval/hono": "8.21.0",
    "@orval/mcp": "8.21.0",
    "@orval/mock": "8.21.0",
    "@orval/query": "8.21.0",
    "@orval/solid-start": "8.21.0",
    "@orval/swr": "8.21.0",
    "@orval/zod": "8.21.0",
    "@scalar/json-magic": "^0.12.16",
    "@scalar/openapi-parser": "^0.28.7",
    "@scalar/openapi-types": "0.8.0",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
